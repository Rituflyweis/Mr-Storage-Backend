            "url": { "raw": "{{baseUrl}}/api/admin/leads?page=1&limit=20", "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }, { "key": "lifecycleStatus", "value": "", "disabled": true }, { "key": "assignedSales", "value": "", "disabled": true }, { "key": "isQuoteReady", "value": "", "disabled": true }] }
          }
        },
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }

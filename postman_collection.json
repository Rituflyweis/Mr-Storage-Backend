{
  "info": {
    "name": "Construction AI — Full API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "staffToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "leadId", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "quotationId", "value": "" },
    { "key": "invoiceId", "value": "" },
    { "key": "scheduleId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "meetingId", "value": "" },
    { "key": "followUpId", "value": "" },
    { "key": "escalationId", "value": "" },
    { "key": "poOrderId", "value": "" },
    { "key": "expenseId", "value": "" },
    { "key": "taxId", "value": "" },
    { "key": "docId", "value": "" },
    { "key": "resetToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth — Staff",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@construction.com\",\n  \"password\": \"Admin@123\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"<refreshToken>\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/logout"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/change-password",
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Admin@123\",\n  \"newPassword\": \"NewPass@456\"\n}" }
          }
        },
        {
          "name": "Forgot Password (Send OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@construction.com\"\n}" }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/verify-otp",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@construction.com\",\n  \"otp\": \"123456\"\n}" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/reset-password",
            "body": { "mode": "raw", "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"NewPass@456\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Public — Chat",
      "item": [
        {
          "name": "Chat Init",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/public/chat/init",
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Arjun\",\n  \"email\": \"arjun@example.com\",\n  \"phone\": \"9876543210\",\n  \"countryCode\": \"+91\"\n}" }
          }
        },
        {
          "name": "Chat History",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/public/chat/history/{{leadId}}"
          }
        }
      ]
    },
    {
      "name": "Admin — Dashboard",
      "item": [
        {
          "name": "Lead Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/dashboard/lead-stats", "query": [{ "key": "startDate", "value": "", "disabled": true }, { "key": "endDate", "value": "", "disabled": true }] }
          }
        },
        {
          "name": "Customer Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }],
            "url": "{{baseUrl}}/api/admin/dashboard/customer-stats"
          }
        },
        {
          "name": "AI vs Human",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }],
            "url": "{{baseUrl}}/api/admin/dashboard/ai-vs-human"
          }
        }
      ]
    },
    {
      "name": "Admin — Customers",
      "item": [
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/customers?page=1&limit=20", "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }, { "key": "search", "value": "", "disabled": true }, { "key": "isActive", "value": "", "disabled": true }] }
          }
        },
        {
          "name": "Get Customer Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }],
            "url": "{{baseUrl}}/api/admin/customers/{{customerId}}"
          }
        },
        {
          "name": "Get Customer Project",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }],
            "url": "{{baseUrl}}/api/admin/customers/{{customerId}}/projects/{{leadId}}"
          }
        },
        {
          "name": "Create Project for Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }
            ],
            "url": "{{baseUrl}}/api/admin/customers/{{customerId}}/leads",
            "body": { "mode": "raw", "raw": "{\n  \"buildingType\": \"Office\",\n  \"location\": \"Bangalore\",\n  \"assignedSales\": \"{{userId}}\"\n}" }
          }
        }
      ]
    },
    {
